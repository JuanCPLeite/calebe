# ============================================================
# Carousel Studio — Variaveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# .env.local NUNCA deve ser commitado no git.
# ============================================================

# ------------------------------------------------------------
# SUPABASE — obrigatorio para o app funcionar
# Encontre em: Supabase Dashboard > Project Settings > API
# ------------------------------------------------------------

# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<SEU_PROJECT_REF>.supabase.co

# Chave anonima (segura para expor no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUA_ANON_KEY>

# Chave service_role (NUNCA expor no frontend — apenas servidor)
# Usada em: api/render/card, api/save-images, api/publish (signed URLs)
SUPABASE_SERVICE_ROLE_KEY=<SUA_SERVICE_ROLE_KEY>

# ------------------------------------------------------------
# APP — obrigatorio em producao, opcional em local
# ------------------------------------------------------------

# URL publica do app (sem barra no final)
# Local: http://localhost:8080
# Producao: https://seudominio.com
NEXT_PUBLIC_APP_URL=http://localhost:8080

# Secret para o endpoint de cron (publicacao agendada)
# Deve ser igual ao secret CRON_SECRET salvo na Edge Function do Supabase
# Gere com: openssl rand -hex 32
CRON_SECRET=

# ------------------------------------------------------------
# ANTHROPIC (Claude) — opcional
# Os tokens de IA sao salvos por usuario no banco (tabela user_tokens).
# Estas variaveis sao fallback server-side para testes sem usuario logado.
# Em producao, deixe em branco — cada usuario cadastra sua propria chave.
# ------------------------------------------------------------

ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# GOOGLE GEMINI — opcional (mesmo motivo do Anthropic)
# ------------------------------------------------------------

GOOGLE_API_KEY=

# ------------------------------------------------------------
# META / INSTAGRAM — opcional
# Tambem gerenciado por usuario na tabela user_tokens.
# Util para testes de publicacao em ambiente de desenvolvimento.
# ------------------------------------------------------------

IG_ACCOUNT_ID=
IG_TOKEN=
