# Supabase — auth + banco + storage
# Encontre em: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (opcional — fallback, tokens vêm do banco por usuário)
ANTHROPIC_API_KEY=

# Google Gemini (opcional — fallback, tokens vêm do banco por usuário)
GOOGLE_API_KEY=

# Meta / Instagram (opcional — fallback legado)
IG_ACCOUNT_ID=
IG_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
